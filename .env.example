# Used by scripts/collect-usage.mjs and the local render/push helpers.
TIDBYTS_API_URL=https://tidbyts.YOUR-SUBDOMAIN.workers.dev
TIDBYTS_INGEST_TOKEN=replace-me
TIDBYTS_READ_TOKEN=replace-me

# Comma-separated device IDs; find them with `pixlet login && pixlet devices`.
TIDBYT_DEVICE_IDS=device-id-one,device-id-two
TIDBYT_API_TOKEN=replace-with-the-api-key-from-the-tidbyt-app

# Optional dedicated-device prototype roles. A prototype is only pushed when
# its role has a device ID, so these can be assigned one display at a time.
TIDBYT_CONTROL_TOWER_DEVICE_ID=
TIDBYT_CONTROL_TOWER_API_TOKEN=
TIDBYT_GLINT_DEVICE_ID=
TIDBYT_GLINT_API_TOKEN=
TIDBYT_BILLABLE_WEEK_DEVICE_ID=
TIDBYT_BILLABLE_WEEK_API_TOKEN=
TIDBYT_EXCEPTION_DEVICE_ID=
TIDBYT_EXCEPTION_API_TOKEN=

# Optional local prototype overrides.
TIDBYTS_BILLABLE_TARGET_HOURS=20
# TIDBYTS_TIMECARD_PATH=/absolute/path/to/timecard.json
# TIDBYTS_CODEX_STATE_PATH=/absolute/path/to/state_5.sqlite

# Optional Exception Screen sources.
TIDBYTS_MONITOR_CI=1
TIDBYTS_GITHUB_REPOSITORY=dockett/mono-playground
# Comma-separated NAME=https://url health checks.
# TIDBYTS_HEALTHCHECKS=PORTAL=https://portal.example.com/health
# When set, the collector queries AWS Cost Explorer and warns at 80%.
# TIDBYTS_AWS_MONTHLY_BUDGET_USD=100
