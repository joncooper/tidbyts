{
  "name": "tidbyts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "types": "wrangler types",
    "types:check": "wrangler types --check",
    "typecheck": "tsc --noEmit && tsc --noEmit -p test/tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:pixlet": "./scripts/check-prototype-renders.sh",
    "docs:screenshots": "./scripts/generate-readme-assets.sh",
    "cf:dry-run": "wrangler deploy --dry-run",
    "db:migrate:local": "wrangler d1 migrations apply tidbyts --local",
    "db:migrate:remote": "wrangler d1 migrations apply tidbyts --remote",
    "check": "npm run types:check && npm run typecheck && npm test && npm run cf:dry-run"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "latest",
    "typescript": "latest",
    "vitest": "latest",
    "wrangler": "latest"
  }
}
