{
  "name": "tidbyts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "types": "wrangler types",
    "types:check": "wrangler types --check",
    "typecheck": "tsc --noEmit && tsc --noEmit -p test/tsconfig.json",
    "test": "vitest run && npm run test:demo",
    "test:demo": "node --test test/demo-static.node.mjs",
    "test:watch": "vitest",
    "test:pixlet": "./scripts/check-prototype-renders.sh",
    "docs:screenshots": "./scripts/generate-readme-assets.sh",
    "demo:assets": "node scripts/build-build-week-video.mjs --assets-only",
    "video:build-week": "node scripts/build-build-week-video.mjs",
    "video:build-week:local": "node scripts/build-build-week-video.mjs --local-voice",
    "cf:dry-run": "wrangler deploy --dry-run",
    "db:migrate:local": "wrangler d1 migrations apply tidbyts --local",
    "db:migrate:remote": "wrangler d1 migrations apply tidbyts --remote",
    "check": "npm run types:check && npm run typecheck && npm test && npm run cf:dry-run"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "latest",
    "typescript": "latest",
    "vitest": "latest",
    "wrangler": "latest"
  }
}
